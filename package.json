{
  "name": "@app/root",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "dev": "turbo run dev --log-prefix=none",
    "format": "biome format --write .",
    "infra:down": "docker compose down",
    "infra:down-v": "docker compose down -v",
    "infra:up": "docker compose up -d",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix",
    "prepare": "effect-language-service patch",
    "sentry:spotlight": "spotlight",
    "setup:context": "./scripts/clone-context.sh",
    "setup:local": "./scripts/env-setup.sh",
    "setup:railway": "./scripts/railway-setup.sh",
    "start": "pnpm --filter @app/web start",
    "test": "vitest run",
    "test:verbose": "VERBOSE=1 vitest run",
    "test:watch": "vitest",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@effect/language-service": "^0.63.2",
    "@effect/sql-drizzle": "catalog:",
    "@effect/sql-pg": "catalog:",
    "@effect/vitest": "catalog:",
    "@spotlightjs/spotlight": "^4.10.0",
    "@testcontainers/postgresql": "catalog:",
    "drizzle-orm": "catalog:",
    "turbo": "^2.8.14",
    "typescript": "catalog:",
    "ultracite": "7.2.5",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.6.5",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "zod": ">=3"
      }
    }
  }
}
